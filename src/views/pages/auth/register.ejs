

<div class="auth-card">
  <div class="auth-card-header">
    <h1>Crear cuenta</h1>
    <p>Rellena los datos para registrarte</p>
  </div>

  <form method="POST" action="/auth/register">
    <div class="auth-body">

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem">
        <div class="field">
          <label for="firstName">Nombre</label>
          <input
            type="text"
            id="firstName"
            name="firstName"
            placeholder="Juan"
            value="<%= typeof values !== 'undefined' && values.firstName ? values.firstName : '' %>"
          />
        </div>
        <div class="field">
          <label for="lastName">Apellido</label>
          <input
            type="text"
            id="lastName"
            name="lastName"
            placeholder="López"
            value="<%= typeof values !== 'undefined' && values.lastName ? values.lastName : '' %>"
          />
        </div>
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="tu@email.com"
          value="<%= typeof values !== 'undefined' && values.email ? values.email : '' %>"
          required
        />
      </div>

      <div class="field">
        <label for="password">Contraseña</label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="Mínimo 8 caracteres"
          required
        />
      </div>

    </div>

    <div class="auth-footer">
      <button type="submit" class="btn btn-primary">Crear cuenta</button>
      <div class="auth-link">
        ¿Ya tienes cuenta? <a href="/auth/login">Iniciar sesión</a>
      </div>
    </div>
  </form>
</div>